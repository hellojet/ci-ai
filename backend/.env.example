# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ci_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_UPLOADS=ci-ai-uploads
MINIO_BUCKET_GENERATED=ci-ai-generated
MINIO_BUCKET_EXPORTS=ci-ai-exports

# Lock
LOCK_HEARTBEAT_TIMEOUT_SECONDS=60
