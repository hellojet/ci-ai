# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ci_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_UPLOADS=ci-ai-uploads
MINIO_BUCKET_GENERATED=ci-ai-generated
MINIO_BUCKET_EXPORTS=ci-ai-exports

# 七牛云对象存储
QINIU_ACCESS_KEY=your-qiniu-access-key
QINIU_SECRET_KEY=your-qiniu-secret-key
QINIU_BUCKET=ci-ai
QINIU_DOMAIN=your-bucket-domain.clouddn.com

# AI 模型默认配置（可在管理后台覆盖，数据库配置优先级更高）
# 文本生成
AI_TEXT_ENDPOINT=https://your-text-api-endpoint
AI_TEXT_MODEL=your-text-model
AI_TEXT_API_KEY=your-text-api-key
AI_TEXT_CONCURRENCY=3
AI_TEXT_TIMEOUT=120
# 图像生成
AI_IMAGE_ENDPOINT=https://your-image-api-endpoint
AI_IMAGE_MODEL=your-image-model
AI_IMAGE_API_KEY=your-image-api-key
AI_IMAGE_CONCURRENCY=2
AI_IMAGE_TIMEOUT=180
# 视频生成
AI_VIDEO_ENDPOINT=https://your-video-api-endpoint
AI_VIDEO_MODEL=your-video-model
AI_VIDEO_API_KEY=your-video-api-key
AI_VIDEO_CONCURRENCY=1
AI_VIDEO_TIMEOUT=300
# 音频生成
AI_AUDIO_ENDPOINT=
AI_AUDIO_MODEL=
AI_AUDIO_API_KEY=
AI_AUDIO_CONCURRENCY=1
AI_AUDIO_TIMEOUT=120

# Lock
LOCK_HEARTBEAT_TIMEOUT_SECONDS=60
